{
  "language_models": {
    "openai_compatible": {
      "OpenQ": {
        "api_url": "https://bench.openq.top/v1",
        "available_models": [
          {
            "name": "gpt-5.5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
    },
  },
  "autosave": "on_focus_change",
  "terminal": {
    "font_size": 15.0,
    "dock": "right",
  },
  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "project_panel": {
    "hide_hidden": false,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "provider": "OpenQ",
      "model": "gpt-5.5",
      "enable_thinking": false,
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "git_panel": {
    "dock": "left",
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "which_key": {
    "enabled": true,
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 18.0,
  "buffer_font_weight": 400.0,
  "buffer_font_size": 18.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "vim_mode": true,
  "server_url": "https://zed.dev",
  "proxy": "",
  "edit_predictions": {
    "provider": "copilot",
  },
  "theme": "Gruvbox Material Neovim Dark",
  "lsp": {
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$name",
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
}
