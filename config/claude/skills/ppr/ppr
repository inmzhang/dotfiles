#!/usr/bin/env bash
# ==============================================================================
# ppr — Ping-Pong Review: multi-agent code review orchestration
#
# A portable CLI for running structured, multi-round code reviews between
# different AI coding agents (Claude Code, Codex, Gemini CLI, OpenCode, etc.)
#
# Agents communicate through files in a .ppr/ directory. Each review round
# produces a diff, reviewer comments, and an author response. Rounds continue
# until all reviewers signal LGTM or a round limit is hit.
#
# Dependencies: bash 4+, jq, git
# ==============================================================================

set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_TARGET="$(readlink "$SCRIPT_SOURCE")"
  if [[ "$SCRIPT_TARGET" = /* ]]; then
    SCRIPT_SOURCE="$SCRIPT_TARGET"
  else
    SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_TARGET"
  fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

PPR_DIR=".ppr"
PPR_CONFIG="$PPR_DIR/config.json"
PPR_STATUS="$PPR_DIR/status.json"
PPR_AGENTS_CONFIG="${PPR_AGENTS_CONFIG:-$SCRIPT_DIR/agents.json}"

# ==============================================================================
# Helpers
# ==============================================================================

die() { echo "ppr: error: $*" >&2; exit 1; }
info() { echo "ppr: $*"; }
wants_help() { [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; }

require_ppr() {
  [ -d "$PPR_DIR" ] || die "not in a ppr session — run 'ppr init' first"
  [ -f "$PPR_STATUS" ] || die "status.json missing — .ppr/ may be corrupt"
}

current_round() {
  jq -r '.current_round' "$PPR_STATUS"
}

round_dir() {
  echo "$PPR_DIR/round-$1"
}

get_reviewers() {
  jq -r '.reviewers | keys[]' "$PPR_STATUS"
}

get_reviewer_status() {
  jq -r ".reviewers[\"$1\"].status" "$PPR_STATUS"
}

update_status() {
  local tmp
  tmp=$(mktemp)
  jq "$1" "$PPR_STATUS" > "$tmp" && mv "$tmp" "$PPR_STATUS"
}

generate_session_id() {
  if command -v uuidgen > /dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
    return
  fi

  if [ -r /proc/sys/kernel/random/uuid ]; then
    tr '[:upper:]' '[:lower:]' < /proc/sys/kernel/random/uuid
    return
  fi

  printf '%s-%s\n' "$(date +%s)" "$RANDOM"
}

capture_snapshot_ref() {
  local snapshot=""
  snapshot=$(git stash create "ppr-snapshot" 2>/dev/null || true)
  if [ -n "$snapshot" ]; then
    echo "$snapshot"
    return 0
  fi

  git rev-parse HEAD 2>/dev/null || true
}

review_verdict() {
  local review_file="$1"

  awk '
    BEGIN { IGNORECASE = 1; verdict = "" }
    /CHANGES[[:space:]]+REQUESTED/ { verdict = "changes_requested" }
    /(^|[^[:alnum:]_])LGTM([^[:alnum:]_]|$)/ { verdict = "lgtm" }
    END { print verdict }
  ' "$review_file"
}

agent_config_file() {
  if [ -f "$PPR_DIR/agents.json" ]; then
    echo "$PPR_DIR/agents.json"
  elif [ -f "$PPR_AGENTS_CONFIG" ]; then
    echo "$PPR_AGENTS_CONFIG"
  else
    die "no agents.json found — create one at .ppr/agents.json or $PPR_AGENTS_CONFIG
See 'ppr help' for the expected format."
  fi
}

# ==============================================================================
# Agent configuration
#
# ppr reads agent launch commands from a JSON config file. Each agent entry
# specifies how to invoke it in non-interactive (print/pipe) mode. The special
# environment variables $PROMPT, $REVIEW_FILE, and $SESSION_ID are set for the
# launched shell so commands can read the generated prompt, write to a review
# path, or resume a stable reviewer session.
#
# Example agents.json:
# {
#   "claude-code": { "cmd": "claude -p --permission-mode plan --output-format text \"$(cat \"$PROMPT\")\"" },
#   "codex":       { "cmd": "codex --ask-for-approval never exec --sandbox read-only -o \"$REVIEW_FILE\" - < \"$PROMPT\"" }
# }
# ==============================================================================

load_agent_field() {
  local agent_type="$1"
  local field_name="$2"
  local config_file=""
  config_file=$(agent_config_file)

  jq -r --arg t "$agent_type" --arg f "$field_name" '.[$t][$f] // empty' "$config_file"
}

load_agent_cmd() {
  local agent_type="$1"
  local cmd
  local config_file=""
  config_file=$(agent_config_file)

  cmd=$(load_agent_field "$agent_type" "cmd")
  [ -n "$cmd" ] || die "agent type '$agent_type' not found in $config_file"
  echo "$cmd"
}

run_agent_command() {
  local cmd_template="$1"
  local prompt_file="$2"
  local review_file="$3"
  local session_id="$4"

  PROMPT="$prompt_file" \
  REVIEW_FILE="$review_file" \
  SESSION_ID="$session_id" \
    bash -c "$cmd_template"
}

# ==============================================================================
# ppr init — start a new review session
#
# Creates the .ppr/ directory structure, captures the current git diff as
# the initial changeset, and writes config and status files.
#
# Usage: ppr init [--reviewers type:name,...] [--max-rounds N] [--context "msg"]
# ==============================================================================

cmd_init() {
  [ ! -d "$PPR_DIR" ] || die ".ppr/ already exists — run 'ppr clean' first if starting over"
  git rev-parse --is-inside-work-tree > /dev/null 2>&1 || die "not in a git repository"

  local reviewers=""
  local max_rounds=3
  local context=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --reviewers) reviewers="$2"; shift 2 ;;
      --max-rounds) max_rounds="$2"; shift 2 ;;
      --context) context="$2"; shift 2 ;;
      *) die "unknown option: $1" ;;
    esac
  done

  [ -n "$reviewers" ] || die "specify reviewers with --reviewers type1:name1,type2:name2"

  # Create directory structure
  mkdir -p "$PPR_DIR/round-1/reviews"

  # Capture changes to review. Prefer staged changes; fall back to unstaged;
  # fall back to last commit.
  local diff_content=""
  diff_content=$(git diff --cached 2>/dev/null) || true
  if [ -z "$diff_content" ]; then
    diff_content=$(git diff 2>/dev/null) || true
  fi
  if [ -z "$diff_content" ]; then
    diff_content=$(git diff HEAD~1 2>/dev/null) || true
  fi
  [ -n "$diff_content" ] || die "no changes found — stage or commit something first"

  echo "$diff_content" > "$PPR_DIR/round-1/changes.diff"

  # Write author context
  if [ -n "$context" ]; then
    echo "$context" > "$PPR_DIR/round-1/context.md"
  else
    echo "(No additional context provided by author.)" > "$PPR_DIR/round-1/context.md"
  fi

  local snapshot_ref=""
  snapshot_ref=$(capture_snapshot_ref)
  [ -n "$snapshot_ref" ] || die "failed to capture current review snapshot"
  echo "$snapshot_ref" > "$PPR_DIR/round-1/snapshot.rev"

  # Build config and status JSON from the reviewer list
  local reviewer_config="{}"
  local reviewer_status="{}"
  IFS=',' read -ra pairs <<< "$reviewers"
  for pair in "${pairs[@]}"; do
    local agent_type="${pair%%:*}"
    local agent_name="${pair##*:}"
    local session_id=""
    session_id=$(generate_session_id)
    reviewer_config=$(echo "$reviewer_config" | jq \
      --arg name "$agent_name" --arg type "$agent_type" --arg session_id "$session_id" \
      '. + {($name): {"type": $type, "session_id": $session_id}}')
    reviewer_status=$(echo "$reviewer_status" | jq \
      --arg name "$agent_name" \
      '. + {($name): {"status": "pending", "lgtm": false}}')
  done

  jq -n \
    --argjson reviewers "$reviewer_config" \
    --argjson max_rounds "$max_rounds" \
    '{reviewers: $reviewers, max_rounds: $max_rounds}' \
    > "$PPR_CONFIG"

  jq -n \
    --argjson reviewers "$reviewer_status" \
    --argjson max_rounds "$max_rounds" \
    '{current_round: 1, max_rounds: $max_rounds, reviewers: $reviewers, state: "awaiting_reviews"}' \
    > "$PPR_STATUS"

  info "initialized review session in .ppr/"
  info "round 1 ready — run 'ppr launch' to start reviewers"
}

# ==============================================================================
# ppr launch — start reviewer agents
#
# Launches one or all reviewer agents in the background. Each agent receives
# a prompt containing the diff, context, and review instructions. The final
# review is captured from stdout unless the agent command uses $REVIEW_FILE.
#
# Usage: ppr launch [reviewer-name]    (omit name to launch all pending)
# ==============================================================================

cmd_launch() {
  require_ppr
  local target="${1:-}"
  local round
  round=$(current_round)
  local rdir
  rdir=$(round_dir "$round")

  launch_one() {
    local name="$1"
    local agent_type
    agent_type=$(jq -r --arg n "$name" '.reviewers[$n].type' "$PPR_CONFIG")
    local cmd_template
    cmd_template=$(load_agent_cmd "$agent_type")
    local session_cmd_template=""
    session_cmd_template=$(load_agent_field "$agent_type" "session_cmd")
    local active_template="$cmd_template"
    if [ "$round" -gt 1 ] && [ -n "$session_cmd_template" ]; then
      active_template="$session_cmd_template"
    fi

    local status
    status=$(get_reviewer_status "$name")
    if [ "$status" = "reviewing" ] || [ "$status" = "done" ]; then
      info "skipping $name (status: $status)"
      return
    fi

    # Build the reviewer prompt
    local prompt_file="$rdir/reviews/.prompt-$name.md"
    generate_reviewer_prompt "$name" "$round" > "$prompt_file"

    # Launch via a fresh shell with prompt/session paths in the environment.
    # Avoid interpolating prompt contents into an eval string; markdown fences
    # and quotes in the generated prompt can otherwise be reinterpreted.
    local review_file="$rdir/reviews/$name.md"
    local session_id=""
    session_id=$(jq -r --arg n "$name" '.reviewers[$n].session_id // empty' "$PPR_CONFIG")
    local stdout_target="$review_file"
    # shellcheck disable=SC2016 — we intentionally match the literal placeholder
    if [[ "$active_template" == *'$REVIEW_FILE'* ]]; then
      stdout_target="$rdir/reviews/.stdout-$name.log"
    fi

    info "launching $name ($agent_type) for round $round..."
    run_agent_command "$active_template" "$prompt_file" "$review_file" "$session_id" \
      > "$stdout_target" 2>"$rdir/reviews/.stderr-$name.log" &
    local pid=$!

    # Record PID so we can track completion
    update_status ".reviewers[\"$name\"].status = \"reviewing\" | .reviewers[\"$name\"].pid = $pid"
    info "$name launched (PID $pid)"
  }

  if [ -n "$target" ]; then
    launch_one "$target"
  else
    for reviewer in $(get_reviewers); do
      launch_one "$reviewer"
    done
  fi
}

# ==============================================================================
# Reviewer prompt generation
#
# Builds the prompt that gets sent to a reviewer agent. The prompt includes
# the diff, author context, and structured instructions on how to write the
# review and where to save it. For round 2+, it also includes the author's
# response to previous review comments.
# ==============================================================================

generate_reviewer_prompt() {
  local name="$1"
  local round="$2"
  local rdir
  rdir=$(round_dir "$round")

  cat <<PROMPT_HEADER
You are participating in a structured code review using the PPR (Ping-Pong Review) protocol.

## Your Role
You are reviewer "$name". Your job is to carefully review the code changes below and provide constructive, actionable feedback.

## Changes to Review (Round $round)
\`\`\`diff
$(cat "$rdir/changes.diff")
\`\`\`

## Author's Context
$(cat "$rdir/context.md")
PROMPT_HEADER

  # For round 2+, include the previous round's reviews and author response
  # so the reviewer has full context of the ongoing conversation.
  if [ "$round" -gt 1 ]; then
    local prev=$((round - 1))
    local prev_dir
    prev_dir=$(round_dir "$prev")

    echo ""
    echo "## Previous Round ($prev) — Your Review"
    if [ -f "$prev_dir/reviews/$name.md" ]; then
      cat "$prev_dir/reviews/$name.md"
    else
      echo "(You did not review in round $prev.)"
    fi

    echo ""
    echo "## Author's Response to Round $prev"
    if [ -f "$prev_dir/response.md" ]; then
      cat "$prev_dir/response.md"
    else
      echo "(No response from author.)"
    fi
  fi

  cat <<'PROMPT_FOOTER'

## Review Instructions

1. Review the code changes carefully for: bugs, logic errors, security issues,
   performance problems, readability, and adherence to project conventions.

2. Write your review as a structured markdown document. For each issue found:
   - Reference the specific file and line
   - Categorize it: [bug], [security], [performance], [style], [suggestion], [question]
   - Explain the problem clearly
   - Suggest a fix if possible

3. At the end of your review, write one of:
   - **LGTM** — if you have no blocking issues (minor suggestions are OK)
   - **CHANGES REQUESTED** — if there are issues that should be addressed

4. IMPORTANT: Output only the final markdown review. If your CLI supports
   a dedicated final-output flag, use it. Otherwise print the review to
   stdout. Do not edit files or apply patches.

PROMPT_FOOTER

  echo "Review output path: $rdir/reviews/$name.md"
  echo ""
  echo "Begin your review now."
}

# ==============================================================================
# ppr status — show current review state
#
# Displays the round number, reviewer status, and whether consensus has been
# reached. Also detects completed reviews by checking for file existence.
# ==============================================================================

cmd_status() {
  require_ppr
  local round
  round=$(current_round)
  local state
  state=$(jq -r '.state' "$PPR_STATUS")
  local max_rounds
  max_rounds=$(jq -r '.max_rounds' "$PPR_STATUS")
  local rdir
  rdir=$(round_dir "$round")

  echo "=== PPR Status ==="
  echo "Round: $round / $max_rounds"
  echo "State: $state"
  echo ""
  echo "Reviewers:"

  local all_done=true
  local all_lgtm=true

  for reviewer in $(get_reviewers); do
    local status
    status=$(get_reviewer_status "$reviewer")
    local lgtm
    lgtm=$(jq -r ".reviewers[\"$reviewer\"].lgtm" "$PPR_STATUS")
    local review_file="$rdir/reviews/$reviewer.md"

    # Auto-detect completion: if the review file exists and has content,
    # mark the reviewer as done.
    if [ "$status" = "reviewing" ] && [ -f "$review_file" ] && [ -s "$review_file" ]; then
      local verdict=""
      verdict=$(review_verdict "$review_file")
      if [ "$verdict" = "lgtm" ]; then
        update_status ".reviewers[\"$reviewer\"].status = \"done\" | .reviewers[\"$reviewer\"].lgtm = true"
        status="done"
        lgtm="true"
      else
        update_status ".reviewers[\"$reviewer\"].status = \"done\" | .reviewers[\"$reviewer\"].lgtm = false"
        status="done"
        lgtm="false"
      fi
    fi

    local indicator="  "
    if [ "$status" = "done" ]; then
      if [ "$lgtm" = "true" ]; then
        indicator="OK"
      else
        indicator="!!"
      fi
    elif [ "$status" = "reviewing" ]; then
      indicator=".."
    fi

    echo "  [$indicator] $reviewer ($status, lgtm=$lgtm)"

    [ "$status" = "done" ] || all_done=false
    [ "$lgtm" = "true" ] || all_lgtm=false
  done

  echo ""
  if $all_done && $all_lgtm; then
    echo "Consensus reached! All reviewers approved."
    update_status '.state = "consensus"'
  elif $all_done; then
    echo "All reviews received. Changes requested — address feedback and run 'ppr respond'."
  elif [ "$state" = "awaiting_reviews" ]; then
    echo "Waiting for reviews..."
  fi
}

# ==============================================================================
# ppr wait — block until all reviews for the current round are in
#
# Polls every few seconds for review files to appear. Useful for scripting
# or when the orchestrating agent wants to pause until reviewers finish.
#
# Usage: ppr wait [--timeout SECONDS]
# ==============================================================================

cmd_wait() {
  require_ppr
  local timeout=600
  [ "${1:-}" = "--timeout" ] && timeout="$2"

  local round
  round=$(current_round)
  local rdir
  rdir=$(round_dir "$round")
  local elapsed=0

  info "waiting for reviews (round $round, timeout ${timeout}s)..."

  while [ "$elapsed" -lt "$timeout" ]; do
    local all_done=true
    for reviewer in $(get_reviewers); do
      local review_file="$rdir/reviews/$reviewer.md"
      if [ ! -f "$review_file" ] || [ ! -s "$review_file" ]; then
        all_done=false
        break
      fi
    done

    if $all_done; then
      info "all reviews received for round $round"
      # Run status to update the status file
      cmd_status > /dev/null 2>&1
      return 0
    fi

    sleep 5
    elapsed=$((elapsed + 5))
  done

  die "timed out waiting for reviews after ${timeout}s"
}

# ==============================================================================
# ppr collect — print all reviews for the current round
#
# Concatenates all review files for easy reading. The orchestrating agent
# typically calls this to read all feedback before deciding how to respond.
# ==============================================================================

cmd_collect() {
  require_ppr
  local round
  round=$(current_round)
  local rdir
  rdir=$(round_dir "$round")

  for reviewer in $(get_reviewers); do
    local review_file="$rdir/reviews/$reviewer.md"
    echo "=== Review from $reviewer ==="
    if [ -f "$review_file" ] && [ -s "$review_file" ]; then
      cat "$review_file"
    else
      echo "(No review yet.)"
    fi
    echo ""
  done
}

# ==============================================================================
# ppr respond — advance to the next review round
#
# After the author has addressed review comments (made code changes and/or
# written a response), this command captures the new diff and prepares the
# next round. If all reviewers gave LGTM, the review is complete.
#
# Usage: ppr respond [--message "response text"]
# ==============================================================================

cmd_respond() {
  require_ppr
  local round
  round=$(current_round)
  local max_rounds
  max_rounds=$(jq -r '.max_rounds' "$PPR_STATUS")
  local rdir
  rdir=$(round_dir "$round")

  local message=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --message) message="$2"; shift 2 ;;
      *) die "unknown option: $1" ;;
    esac
  done

  # Save author's response for this round
  if [ -n "$message" ]; then
    echo "$message" > "$rdir/response.md"
  fi

  # Check if we've hit consensus
  local all_lgtm=true
  for reviewer in $(get_reviewers); do
    local lgtm
    lgtm=$(jq -r ".reviewers[\"$reviewer\"].lgtm" "$PPR_STATUS")
    [ "$lgtm" = "true" ] || all_lgtm=false
  done

  if $all_lgtm; then
    info "all reviewers approved — review complete!"
    update_status '.state = "consensus"'
    return 0
  fi

  # Check round limit
  local next_round=$((round + 1))
  if [ "$next_round" -gt "$max_rounds" ]; then
    info "reached max rounds ($max_rounds) — ending review"
    update_status '.state = "max_rounds_reached"'
    return 0
  fi

  # Prepare next round
  local next_dir
  next_dir=$(round_dir "$next_round")
  mkdir -p "$next_dir/reviews"

  # Capture the new changeset as the diff between the previous round snapshot
  # and the current tracked workspace snapshot.
  local diff_content=""
  local prev_snapshot=""
  local current_snapshot=""
  if [ -f "$rdir/snapshot.rev" ]; then
    prev_snapshot=$(cat "$rdir/snapshot.rev")
  fi
  current_snapshot=$(capture_snapshot_ref)

  if [ -n "$prev_snapshot" ] && [ -n "$current_snapshot" ]; then
    diff_content=$(git diff "$prev_snapshot" "$current_snapshot" 2>/dev/null) || true
  else
    diff_content=$(git diff --cached 2>/dev/null) || true
    [ -n "$diff_content" ] || diff_content=$(git diff 2>/dev/null) || true
  fi

  [ -n "$diff_content" ] || echo "(No new changes since last round.)" > "$next_dir/changes.diff"
  [ -z "$diff_content" ] || echo "$diff_content" > "$next_dir/changes.diff"
  if [ -n "$current_snapshot" ]; then
    echo "$current_snapshot" > "$next_dir/snapshot.rev"
  elif [ -n "$prev_snapshot" ]; then
    echo "$prev_snapshot" > "$next_dir/snapshot.rev"
  fi

  # Carry forward context
  if [ -n "$message" ]; then
    echo "$message" > "$next_dir/context.md"
  else
    echo "(Author made changes without additional comment.)" > "$next_dir/context.md"
  fi

  # Reset reviewer statuses for the new round
  for reviewer in $(get_reviewers); do
    local prev_lgtm
    prev_lgtm=$(jq -r ".reviewers[\"$reviewer\"].lgtm" "$PPR_STATUS")
    if [ "$prev_lgtm" = "true" ]; then
      # Reviewers who already LGTM'd keep their status — they don't need
      # to review again unless the author specifically requests it.
      update_status ".reviewers[\"$reviewer\"].status = \"done\""
    else
      update_status ".reviewers[\"$reviewer\"].status = \"pending\" | .reviewers[\"$reviewer\"].lgtm = false"
    fi
  done

  update_status ".current_round = $next_round | .state = \"awaiting_reviews\""
  info "advanced to round $next_round — run 'ppr launch' to start reviewers"
}

# ==============================================================================
# ppr finish — generate a review summary and optionally commit
#
# Produces a markdown summary of the entire review process: rounds, issues
# raised, resolutions, and final status. Optionally creates a git commit
# with the summary in the commit message.
#
# Usage: ppr finish [--commit] [--message "commit message"]
# ==============================================================================

cmd_finish() {
  require_ppr
  local do_commit=false
  local commit_msg=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --commit) do_commit=true; shift ;;
      --message) commit_msg="$2"; shift 2 ;;
      *) die "unknown option: $1" ;;
    esac
  done

  local round
  round=$(current_round)
  local state
  state=$(jq -r '.state' "$PPR_STATUS")

  # Generate summary
  local summary="$PPR_DIR/summary.md"
  {
    echo "# PPR Review Summary"
    echo ""
    echo "- **Rounds**: $round"
    echo "- **Final state**: $state"
    echo "- **Reviewers**: $(get_reviewers | tr '\n' ', ' | sed 's/,$//')"
    echo ""

    for r in $(seq 1 "$round"); do
      local rd
      rd=$(round_dir "$r")
      [ -d "$rd" ] || continue

      echo "## Round $r"
      echo ""
      for reviewer in $(get_reviewers); do
        local rf="$rd/reviews/$reviewer.md"
        if [ -f "$rf" ] && [ -s "$rf" ]; then
          echo "### $reviewer"
          cat "$rf"
          echo ""
        fi
      done

      if [ -f "$rd/response.md" ]; then
        echo "### Author Response"
        cat "$rd/response.md"
        echo ""
      fi
    done
  } > "$summary"

  info "review summary written to $summary"

  if $do_commit; then
    if [ -z "$commit_msg" ]; then
      commit_msg="reviewed changes (ppr: $round rounds, $state)"
    fi
    git add -A
    git commit -m "$commit_msg"
    info "committed with message: $commit_msg"
  fi
}

# ==============================================================================
# ppr clean — remove the .ppr/ directory
# ==============================================================================

cmd_clean() {
  if [ -d "$PPR_DIR" ]; then
    rm -rf "$PPR_DIR"
    info "removed $PPR_DIR"
  else
    info "nothing to clean"
  fi
}

# ==============================================================================
# ppr help
# ==============================================================================

help_main() {
  cat <<'HELP'
ppr — Ping-Pong Review: multi-agent code review orchestration

Usage: ppr <command> [options]

Commands:
  init      Start a new review session
              --reviewers type1:name1,type2:name2  (required)
              --max-rounds N                       (default: 3)
              --context "description of changes"

  launch    Launch reviewer agents (background, non-blocking)
              [reviewer-name]   Launch specific reviewer, or all if omitted

  status    Show current review state and detect completed reviews

  wait      Block until all reviews for the current round are in
              --timeout SECONDS  (default: 600)

  collect   Print all reviews for the current round

  respond   Address feedback and advance to next round
              --message "response text"

  finish    Generate review summary and optionally commit
              --commit           Create a git commit
              --message "msg"    Custom commit message

  clean     Remove the .ppr/ directory

Agent Configuration:
  ppr reads agent launch commands from agents.json. It checks:
    1. .ppr/agents.json (project-local)
    2. agents.json next to the ppr script

  Example agents.json:
  {
    "claude-code": {
      "cmd": "claude -p --session-id \"$SESSION_ID\" --permission-mode plan --output-format text \"$(cat \"$PROMPT\")\"",
      "session_cmd": "claude -p --resume \"$SESSION_ID\" --permission-mode plan --output-format text \"$(cat \"$PROMPT\")\""
    },
    "codex": {
      "cmd": "codex --ask-for-approval never exec --sandbox read-only -o \"$REVIEW_FILE\" - < \"$PROMPT\""
    },
    "gemini": {
      "cmd": "gemini -p \"$(cat \"$PROMPT\")\" --approval-mode plan --output-format text"
    }
  }

  The launched shell receives $PROMPT as the path to a temporary file
  containing the reviewer's prompt. The optional $REVIEW_FILE variable points
  at the destination markdown file for CLIs that support writing only the
  final answer to a path. The optional $SESSION_ID variable is a stable
  per-reviewer session identifier. If a session_cmd template is provided, ppr
  uses it from round 2 onward. If $REVIEW_FILE is not used, ppr captures
  stdout into the per-reviewer markdown file.

Environment:
  PPR_AGENTS_CONFIG  Path to agents.json (default: agents.json next to ppr)

HELP
}

help_init() {
  cat <<'HELP'
Usage: ppr init --reviewers type1:name1,type2:name2 [--max-rounds N] [--context "description of changes"]

Start a new review session in .ppr/.

Options:
  --reviewers   Required reviewer list in agent-type:name format
  --max-rounds  Maximum review rounds before stopping (default: 3)
  --context     Short author context saved into round 1

Examples:
  ppr init --reviewers "claude-code:alice,codex:bob"
  ppr init --reviewers "codex:bob" --max-rounds 2 --context "Refactor parser error handling"
HELP
}

help_launch() {
  cat <<'HELP'
Usage: ppr launch [reviewer-name]

Launch reviewer agents for the current round.

Arguments:
  reviewer-name  Optional reviewer to launch. If omitted, launches all pending reviewers.
HELP
}

help_status() {
  cat <<'HELP'
Usage: ppr status

Show the current round, per-reviewer status, and consensus state.
HELP
}

help_wait() {
  cat <<'HELP'
Usage: ppr wait [--timeout SECONDS]

Block until all reviews for the current round are present.

Options:
  --timeout  Maximum wait time in seconds (default: 600)
HELP
}

help_collect() {
  cat <<'HELP'
Usage: ppr collect

Print all reviews for the current round.
HELP
}

help_respond() {
  cat <<'HELP'
Usage: ppr respond [--message "response text"]

Advance to the next round after addressing reviewer feedback.

Options:
  --message  Optional author response recorded for the round
HELP
}

help_finish() {
  cat <<'HELP'
Usage: ppr finish [--commit] [--message "commit message"]

Generate a markdown review summary and optionally create a git commit.

Options:
  --commit   Create a git commit after writing .ppr/summary.md
  --message  Custom commit message
HELP
}

help_clean() {
  cat <<'HELP'
Usage: ppr clean

Remove the .ppr/ directory for the current review session.
HELP
}

cmd_help() {
  case "${1:-}" in
    ""|main|overview) help_main ;;
    init) help_init ;;
    launch) help_launch ;;
    status) help_status ;;
    wait) help_wait ;;
    collect) help_collect ;;
    respond) help_respond ;;
    finish) help_finish ;;
    clean) help_clean ;;
    *) die "unknown help topic: $1 — run 'ppr help'" ;;
  esac
}

# ==============================================================================
# Main dispatch
# ==============================================================================

case "${1:-help}" in
  init)
    if wants_help "${2:-}"; then
      cmd_help init
    else
      shift
      cmd_init "$@"
    fi
    ;;
  launch)
    if wants_help "${2:-}"; then
      cmd_help launch
    else
      shift
      cmd_launch "$@"
    fi
    ;;
  status)
    if wants_help "${2:-}"; then
      cmd_help status
    else
      shift
      cmd_status "$@"
    fi
    ;;
  wait)
    if wants_help "${2:-}"; then
      cmd_help wait
    else
      shift
      cmd_wait "$@"
    fi
    ;;
  collect)
    if wants_help "${2:-}"; then
      cmd_help collect
    else
      shift
      cmd_collect "$@"
    fi
    ;;
  respond)
    if wants_help "${2:-}"; then
      cmd_help respond
    else
      shift
      cmd_respond "$@"
    fi
    ;;
  finish)
    if wants_help "${2:-}"; then
      cmd_help finish
    else
      shift
      cmd_finish "$@"
    fi
    ;;
  clean)
    if wants_help "${2:-}"; then
      cmd_help clean
    else
      shift
      cmd_clean "$@"
    fi
    ;;
  help)
    shift
    if wants_help "${1:-}"; then
      cmd_help
    else
      cmd_help "${1:-}"
    fi
    ;;
  --help|-h) cmd_help ;;
  *) die "unknown command: $1 — run 'ppr help'" ;;
esac
